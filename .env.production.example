# Variáveis pra colar no painel da VPS (Coolify/Dokploy/Easypanel)
# NUNCA commitar valores reais — esse arquivo é só template.

# ── Supabase (cloud — projeto ydnwqptkrftonunyjzoc) ─────────────
NEXT_PUBLIC_SUPABASE_URL=https://ydnwqptkrftonunyjzoc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # Settings → API → service_role
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...       # Settings → API → anon (opcional)

# ── Auth ───────────────────────────────────────────────────────
# Gere com: openssl rand -base64 48
JWT_SECRET=troque-isto-por-um-segredo-de-pelo-menos-48-chars

# ── Email transacional (Brevo) ─────────────────────────────────
# API key v3 em Brevo → Settings → SMTP & API → API keys
BREVO_API_KEY=xkeysib-...
# Remetente VERIFICADO no Brevo (Senders, domains, IPs)
BREVO_SENDER_EMAIL=equipe@perciconsultoria.com.br
BREVO_SENDER_NAME=Perci Consultoria
# Opcional: URL pública usada nos links de email (senão deriva da request)
# NEXT_PUBLIC_APP_URL=https://app.seudominio.com

# ── Runtime ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
