# Variáveis pra colar no painel da VPS (Coolify/Dokploy/Easypanel)
# NUNCA commitar valores reais — esse arquivo é só template.

# ── Supabase (cloud — projeto ydnwqptkrftonunyjzoc) ─────────────
# ATENÇÃO: as chaves legadas (eyJ...) foram DESATIVADAS pelo Supabase.
# Use as chaves NOVAS em Settings → API Keys.
NEXT_PUBLIC_SUPABASE_URL=https://ydnwqptkrftonunyjzoc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...        # API Keys → Secret keys (NÃO a legada)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_... # API Keys → Publishable (opcional)

# ── Auth ───────────────────────────────────────────────────────
# Gere com: openssl rand -base64 48
JWT_SECRET=troque-isto-por-um-segredo-de-pelo-menos-48-chars

# ── Email transacional (Brevo) ─────────────────────────────────
# Reset de senha e email de acesso. Sem isso, envios são só logados (dev).
BREVO_API_KEY=xkeysib-...                   # Brevo → SMTP & API → API Keys
BREVO_SENDER_EMAIL=acesso@seu-dominio.com   # remetente verificado na Brevo
BREVO_SENDER_NAME=Ordum
# Base usada nos links dos emails (sem barra no fim)
NEXT_PUBLIC_APP_URL=https://gestor-tarefas-ana.vercel.app

# ── Runtime ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
